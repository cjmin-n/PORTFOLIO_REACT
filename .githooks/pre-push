#!/usr/bin/env bash
# Vercel CI 빌드 시뮬레이션. push 전에 ESLint warning이 error로 승격된 상태에서
# 빌드가 통과하는지 검증. 실패 시 push 차단.
#
# 우회가 필요한 긴급 상황: git push --no-verify
#
# fetch:notion은 skip하고 react-scripts build만 실행 (네트워크 호출 최소화).

set -e

# 푸시될 commit 범위에서 React/빌드 영향 파일이 변경됐는지 확인
needs_check=0
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # 새 브랜치 push인 경우: 전체 검사
        needs_check=1
        break
    fi
    if git diff --name-only "$remote_sha..$local_sha" 2>/dev/null \
        | grep -qE '^(src/|public/|package(-lock)?\.json|tailwind\.config|scripts/)' ; then
        needs_check=1
        break
    fi
done

if [ "$needs_check" -eq 0 ]; then
    echo "▶ pre-push: React 무관 변경만 있음 → 빌드 검증 skip"
    exit 0
fi

echo "▶ pre-push: Vercel CI 빌드 검증 시작..."
LOG=/tmp/portfolio-pre-push.log
if ! CI=true npx react-scripts build > "$LOG" 2>&1; then
    echo ""
    echo "❌ Vercel CI 빌드 실패 (ESLint warning이 error로 승격됨)"
    echo ""
    echo "── 로그 마지막 30줄 ──────────────────────────────────"
    tail -30 "$LOG"
    echo "─────────────────────────────────────────────────"
    echo ""
    echo "전체 로그: $LOG"
    echo "수정 후 다시 push, 또는 긴급 우회: git push --no-verify"
    exit 1
fi
echo "✓ pre-push: CI 빌드 통과"
exit 0

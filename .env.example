# ============================================================
# .env.example — 환경 변수 템플릿
# ============================================================
# 사용법:
#   1) 이 파일을 .env.local 로 복사
#   2) 아래 각 항목을 실제 값으로 채우기
#   3) .env.local 은 .gitignore 되어 있으니 그대로 두면 됨 (절대 커밋 X)
#
# 신규 컨트리뷰터/배포 환경(Vercel·Oracle Cloud)에 어떤 값이 필요한지
# 빠르게 파악하기 위한 참고 파일.
# ============================================================


# ─────────────────────────────────────────────────────────────
# [Notion]  scripts/fetch-notion.js 가 빌드 타임에 사용
# ─────────────────────────────────────────────────────────────

# Notion Internal Integration Token (https://www.notion.so/profile/integrations)
# "Portfolio Bot" 같은 Integration 생성 후 발급되는 secret_xxx 값
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Projects DB ID. 아래 세 가지 형태 모두 OK (코드가 normalize함)
#   1) URL slug 그대로:   Projects-36e4cda2029380f1acabf73595ed4d02
#   2) 32자리 hex:        36e4cda2029380f1acabf73595ed4d02
#   3) UUID:              36e4cda2-0293-80f1-acab-f73595ed4d02
NOTION_PROJECTS_DB_ID=Projects-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
# [Telegram Bot]  bot/ Python 봇이 사용 (Phase 2)
# ─────────────────────────────────────────────────────────────

# @BotFather 에서 /newbot 으로 봇 생성 후 발급받은 토큰
# 형식: "{숫자}:{영숫자}"
TELEGRAM_BOT_TOKEN=7891234567:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 본인 Telegram user_id (숫자).
# @userinfobot 에서 /start 하면 "Id: 123456789" 형태로 알려줌.
# 봇은 이 user_id 외 메시지는 전부 무시함 (외부인 차단).
TELEGRAM_OWNER_USER_ID=123456789


# ─────────────────────────────────────────────────────────────
# [Vercel]  봇이 Notion 적재 후 자동 사이트 재빌드 트리거
# ─────────────────────────────────────────────────────────────

# Vercel 대시보드 → 프로젝트 → Settings → Git → Deploy Hooks
# 에서 "Create Hook" 한 뒤 발급되는 URL 그대로
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxxxx/yyyyyyyyyy


# ─────────────────────────────────────────────────────────────
# [Anthropic Claude]  Phase 3에서 자연어 입력 파싱에 사용 (선택)
# ─────────────────────────────────────────────────────────────

# Phase 3 (자연어 파싱) 단계 전엔 비워둬도 됨.
# Console: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
